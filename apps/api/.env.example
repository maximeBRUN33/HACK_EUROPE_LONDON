# Legacy Atlas API environment template

# -----------------------------
# Core runtime
# -----------------------------
LEGACY_ATLAS_SYNC_JOBS=0
LEGACY_ATLAS_JOB_WORKERS=2
LEGACY_ATLAS_ENABLE_GIT_INGESTION=1
LEGACY_ATLAS_LOG_LEVEL=INFO
LEGACY_ATLAS_AST_PROGRESS_EVERY=100
LEGACY_ATLAS_CODEWORDS_RUNTIME_HOOK=1

# Optional custom paths
# LEGACY_ATLAS_REPO_CACHE=/absolute/path/to/repo-cache
# LEGACY_ATLAS_REPO_ROOTS=/absolute/path/to/local/repos

# -----------------------------
# CodeWords runtime integration
# -----------------------------
# Defaults to MCP config URL when omitted.
CODEWORDS_RUNTIME_BASE_URL=https://runtime.codewords.ai
CODEWORDS_API_KEY=replace_with_codewords_api_key
CODEWORDS_RUNTIME_SERVICE_ID=legacy_atlas_post_analysis_v1_8a477024
CODEWORDS_POLL_MAX_ATTEMPTS=8
CODEWORDS_POLL_INTERVAL_SEC=1.5

# -----------------------------
# Dust semantic copilot integration
# -----------------------------
DUST_API_BASE_URL=https://dust.tt/api/v1
DUST_WORKSPACE_ID=replace_with_dust_workspace_id
DUST_API_KEY=replace_with_dust_api_key
DUST_ASSISTANT_CONFIGURATION_ID=replace_with_dust_assistant_configuration_id

# -----------------------------
# Gemini web comparison integration
# -----------------------------
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=replace_with_gemini_api_key
